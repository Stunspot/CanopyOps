{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://collaborativedynamics.example/canopyops/facility-profile.schema.json",
  "title": "CanopyOps Facility Profile",
  "type": "object",
  "required": ["facility_id", "jurisdiction", "profile_owner", "last_verified", "rooms", "approval_roles"],
  "properties": {
    "facility_id": {"type": "string", "minLength": 1},
    "jurisdiction": {"type": "string", "minLength": 1},
    "license_context": {"type": "string"},
    "profile_owner": {"type": "string", "minLength": 1},
    "last_verified": {"type": "string", "format": "date"},
    "rooms": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["room_id", "intended_stages"], "properties": {"room_id": {"type": "string"}, "intended_stages": {"type": "array", "items": {"type": "string"}}, "constraints": {"type": "object"}}}},
    "approval_roles": {"type": "object", "minProperties": 1},
    "capability_limits": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
