{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://collaborativedynamics.example/canopyops/crop-plan.schema.json",
  "title": "CanopyOps Crop Plan",
  "type": "object",
  "required": ["plan_id", "version", "status", "facility_profile", "room", "crop_profiles", "stages", "owner", "review_state"],
  "properties": {
    "plan_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft", "provisional", "ready-for-review", "awaiting-authority", "authorized", "superseded"]},
    "facility_profile": {"type": "string", "minLength": 1},
    "room": {"type": "string", "minLength": 1},
    "crop_profiles": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "stages": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "advance_criteria", "monitoring", "owner"], "properties": {"name": {"type": "string"}, "advance_criteria": {"type": "string"}, "monitoring": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "owner": {"type": "string"}}}},
    "owner": {"type": "string", "minLength": 1},
    "review_state": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
